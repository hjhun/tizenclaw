{
  "enabled": true,
  "evaluation_session": "autonomous",
  "max_evaluations_per_hour": 10,
  "notification_channel": "telegram",
  "trigger_rules": [
    {
      "name": "low_battery_alert",
      "event_type": "battery.level_changed",
      "condition": {"level": {"$lt": 15}},
      "cooldown_minutes": 30,
      "action": "evaluate"
    },
    {
      "name": "battery_critical",
      "event_type": "battery.level_changed",
      "condition": {"level": {"$lt": 5}},
      "cooldown_minutes": 10,
      "action": "direct",
      "direct_prompt": "배터리가 5% 미만입니다. 즉시 충전이 필요합니다. 사용자에게 경고하고 불필요한 프로세스를 종료할 방법을 제안해주세요."
    },
    {
      "name": "network_lost",
      "event_type": "network.disconnected",
      "condition": {},
      "cooldown_minutes": 5,
      "action": "evaluate"
    },
    {
      "name": "memory_critical",
      "event_type": "memory.critical",
      "condition": {"level": {"$eq": "critical"}},
      "cooldown_minutes": 10,
      "action": "direct",
      "direct_prompt": "시스템 메모리가 위험 수준입니다. 메모리 사용량을 분석하고 불필요한 프로세스를 종료하는 방법을 제안해주세요."
    },
    {
      "name": "perception_warning",
      "event_type": "perception.situation_changed",
      "condition": {"level": {"$gte": 2}},
      "cooldown_minutes": 15,
      "action": "evaluate"
    },
    {
      "name": "perception_critical",
      "event_type": "perception.situation_changed",
      "condition": {"level": {"$gte": 3}},
      "cooldown_minutes": 5,
      "action": "direct",
      "direct_prompt": "Perception Engine이 디바이스 위험 상태를 감지했습니다. 현재 복합적 위험 요인을 분석하고, 사용자에게 구체적인 해결 방법을 제안해주세요."
    },
    {
      "name": "storage_low",
      "event_type": "storage.low_space",
      "condition": {"available_percent": {"$lt": 10}},
      "cooldown_minutes": 60,
      "action": "evaluate"
    },
    {
      "name": "app_crash_detected",
      "event_type": "app.crashed",
      "condition": {},
      "cooldown_minutes": 5,
      "action": "evaluate"
    },
    {
      "name": "thermal_warning",
      "event_type": "thermal.high",
      "condition": {"temperature": {"$gt": 45}},
      "cooldown_minutes": 15,
      "action": "direct",
      "direct_prompt": "디바이스 온도가 높습니다. CPU 부하를 분석하고 불필요한 작업을 줄이는 방법을 제안해주세요."
    }
  ]
}
