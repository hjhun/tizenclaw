{
  "bounds": {
    "control_oven_temperature": [
      {
        "param": "temperature",
        "min": 0,
        "max": 250,
        "unit": "celsius",
        "description": "Maximum safe oven temperature"
      }
    ],
    "set_cook_program": [
      {
        "param": "temperature",
        "min": 0,
        "max": 250,
        "unit": "celsius",
        "description": "Maximum safe cooking temperature"
      },
      {
        "param": "duration_minutes",
        "min": 1,
        "max": 480,
        "unit": "minutes",
        "description": "Maximum cooking duration (8 hours)"
      }
    ],
    "start_wash_cycle": [
      {
        "param": "spin_rpm",
        "min": 0,
        "max": 1400,
        "unit": "rpm",
        "description": "Maximum safe spin speed"
      },
      {
        "param": "temperature",
        "min": 0,
        "max": 95,
        "unit": "celsius",
        "description": "Maximum safe wash water temperature"
      }
    ],
    "set_temperature_zone": [
      {
        "param": "temperature",
        "min": -25,
        "max": 10,
        "unit": "celsius",
        "description": "Refrigerator temperature range"
      }
    ],
    "control_volume": [
      {
        "param": "level",
        "min": 0,
        "max": 100,
        "unit": "percent",
        "description": "Volume level range"
      }
    ],
    "control_display": [
      {
        "param": "brightness",
        "min": 0,
        "max": 100,
        "unit": "percent",
        "description": "Display brightness range"
      }
    ]
  },
  "rate_limits": {
    "control_oven_temperature": {
      "max_calls": 5,
      "window_seconds": 60
    },
    "start_wash_cycle": {
      "max_calls": 3,
      "window_seconds": 300
    },
    "preheat_oven": {
      "max_calls": 3,
      "window_seconds": 120
    },
    "send_notification": {
      "max_calls": 10,
      "window_seconds": 60
    }
  },
  "confirmation_required": [
    "preheat_oven",
    "start_wash_cycle",
    "set_cook_program",
    "control_power",
    "terminate_app"
  ]
}
