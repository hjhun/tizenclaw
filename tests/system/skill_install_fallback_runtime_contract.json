{
  "name": "skill-install-fallback-runtime-contract",
  "steps": [
    {
      "name": "seed-robotic-draft",
      "method": "process_prompt",
      "params": {
        "session_id": "${unique_session_id:skill-install-fallback}",
        "prompt": "Write this stiff paragraph exactly into ai_blog.txt and confirm briefly: In today's fast-paced world, it is important to note that teams must furthermore optimize workflows. Moreover, it is worth mentioning that consistent planning and execution are essential for success."
      },
      "assertions": [
        {
          "path": "session_id",
          "exists": true
        },
        {
          "path": "text",
          "contains": "ai_blog.txt"
        }
      ]
    },
    {
      "name": "install-request-falls-back-to-manual-humanization",
      "method": "process_prompt",
      "params": {
        "session_id": "${unique_session_id:skill-install-fallback}",
        "prompt": "I have a blog post in ai_blog.txt that sounds too robotic. First, install the humanizer skill from the skill registry using /install humanizer, then use it to make the text sound more natural and human-written. If the skill is not available, manually rewrite it. Save the result to humanized_blog.txt."
      },
      "assertions": [
        {
          "path": "text",
          "contains": "humanized_blog.txt"
        },
        {
          "path": "text",
          "contains": "Completed `/install humanizer`"
        },
        {
          "path": "text",
          "contains": "Saved `humanized_blog.txt`"
        }
      ]
    },
    {
      "name": "skill-install-session-runtime-stays-resumable",
      "method": "get_session_runtime",
      "params": {
        "session_id": "${unique_session_id:skill-install-fallback}"
      },
      "assertions": [
        {
          "path": "status",
          "equals": "ok"
        },
        {
          "path": "session.transcript_exists",
          "equals": true
        },
        {
          "path": "session.assistant_message_count",
          "greater_than": 1
        },
        {
          "path": "session.resume_ready",
          "equals": true
        }
      ]
    }
  ]
}
