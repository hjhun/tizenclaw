{
  "name": "devel-mode-scheduler",
  "steps": [
    {
      "name": "list-devel-tasks",
      "method": "list_tasks",
      "params": {},
      "assertions": [
        {
          "path": "status",
          "equals": "success"
        },
        {
          "path": "count",
          "equals": 1
        },
        {
          "path": "tasks.0.id",
          "equals": "devel-autonomous-cycle"
        },
        {
          "path": "tasks.0.schedule",
          "equals": "interval 30m"
        },
        {
          "path": "tasks.0.project_dir",
          "exists": true
        },
        {
          "path": "tasks.0.coding_backend",
          "equals": "codex"
        },
        {
          "path": "tasks.0.execution_mode",
          "equals": "plan"
        },
        {
          "path": "tasks.0.auto_approve",
          "equals": true
        },
        {
          "path": "tasks.0.prompt",
          "contains": ".dev_note/ROADMAP.md"
        }
      ]
    }
  ]
}
