{
  "name": "json-only-transcript-runtime-contract",
  "offline_safe": true,
  "steps": [
    {
      "name": "prompt-persists-json-only-assistant-response",
      "method": "process_prompt",
      "params": {
        "session_id": "${unique_session_id:json-only-transcript}",
        "prompt": "Save the following to memory/MEMORY.md and confirm briefly: {\"status\":\"verified\",\"test\":\"json_only_transcript_runtime_contract\",\"assertion\":\"assistant output is captured durably in the session transcript store regardless of response format, including concise structured responses without prose wrapping\"}"
      },
      "assertions": [
        {
          "path": "session_id",
          "exists": true
        },
        {
          "path": "text",
          "contains": "{"
        }
      ]
    },
    {
      "name": "session-runtime-reports-assistant-transcript",
      "method": "get_session_runtime",
      "params": {
        "session_id": "${unique_session_id:json-only-transcript}"
      },
      "assertions": [
        {
          "path": "status",
          "equals": "ok"
        },
        {
          "path": "session.transcript_exists",
          "equals": true
        },
        {
          "path": "session.assistant_message_count",
          "greater_than": 0
        },
        {
          "path": "session.resume_ready",
          "equals": true
        }
      ]
    }
  ]
}
