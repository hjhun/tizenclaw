{
  "name": "json-only-transcript-runtime-contract",
  "offline_safe": true,
  "steps": [
    {
      "name": "prompt-persists-json-only-assistant-response",
      "method": "process_prompt",
      "params": {
        "session_id": "${unique_session_id:json-only-transcript}",
        "prompt": "You are a validation function. Your ONLY job is to output a single JSON object.\nDo NOT use any tools.\nRespond with ONLY this JSON structure (no markdown, no code fences, no extra text): {\"status\":\"verified\",\"transcript_durable\":true}"
      },
      "assertions": [
        {
          "path": "session_id",
          "exists": true
        },
        {
          "path": "text",
          "contains": "transcript_durable"
        }
      ]
    },
    {
      "name": "session-runtime-reports-assistant-transcript",
      "method": "get_session_runtime",
      "params": {
        "session_id": "${unique_session_id:json-only-transcript}"
      },
      "assertions": [
        {
          "path": "status",
          "equals": "ok"
        },
        {
          "path": "session.transcript_exists",
          "equals": true
        },
        {
          "path": "session.assistant_message_count",
          "greater_than": 0
        },
        {
          "path": "session.resume_ready",
          "equals": true
        }
      ]
    }
  ]
}
