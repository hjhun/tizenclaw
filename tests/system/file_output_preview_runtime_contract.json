{
  "name": "file-output-preview-runtime-contract",
  "offline_safe": true,
  "steps": [
    {
      "name": "writing-prompt-returns-preview-aware-completion",
      "method": "process_prompt",
      "params": {
        "session_id": "${unique_session_id:file-output-preview}",
        "prompt": "List upcoming tech conferences in 2026 and save a roundup to article.md."
      },
      "assertions": [
        {
          "path": "session_id",
          "exists": true
        },
        {
          "path": "text",
          "contains": "Preview of `article.md`"
        }
      ]
    },
    {
      "name": "preview-session-runtime-remains-resumable",
      "method": "get_session_runtime",
      "params": {
        "session_id": "${unique_session_id:file-output-preview}"
      },
      "assertions": [
        {
          "path": "status",
          "equals": "ok"
        },
        {
          "path": "session.resume_ready",
          "equals": true
        },
        {
          "path": "session.transcript_exists",
          "equals": true
        }
      ]
    }
  ]
}
