{
  "name": "structured-writing-runtime-contract",
  "offline_safe": true,
  "steps": [
    {
      "name": "writing-prompt-produces-session-output",
      "method": "process_prompt",
      "params": {
        "session_id": "${unique_session_id:structured-writing}",
        "prompt": "List upcoming tech conferences in 2026 and save a roundup to article.md."
      },
      "assertions": [
        {
          "path": "session_id",
          "exists": true
        },
        {
          "path": "text",
          "exists": true
        }
      ]
    },
    {
      "name": "writing-session-runtime-reports-transcript",
      "method": "get_session_runtime",
      "params": {
        "session_id": "${unique_session_id:structured-writing}"
      },
      "assertions": [
        {
          "path": "status",
          "equals": "ok"
        },
        {
          "path": "session.transcript_exists",
          "equals": true
        },
        {
          "path": "session.assistant_message_count",
          "greater_than": 0
        },
        {
          "path": "session.workdir_path",
          "contains": "workdirs"
        },
        {
          "path": "session.resume_ready",
          "equals": true
        }
      ]
    }
  ]
}
