{
  "name": "session-transcript-runtime-contract",
  "offline_safe": true,
  "steps": [
    {
      "name": "prompt-creates-session-transcript",
      "method": "process_prompt",
      "params": {
        "session_id": "${unique_session_id:session-transcript}",
        "prompt": "Save the following to memory/MEMORY.md and confirm briefly: Transcript runtime contract verified. The session persistence mechanism is functioning correctly and storing assistant messages as expected. This note exists only to exercise the durable transcript path without requiring a live LLM backend."
      },
      "assertions": [
        {
          "path": "session_id",
          "exists": true
        },
        {
          "path": "text",
          "exists": true
        }
      ]
    },
    {
      "name": "session-runtime-reports-transcript-artifacts",
      "method": "get_session_runtime",
      "params": {
        "session_id": "${unique_session_id:session-transcript}"
      },
      "assertions": [
        {
          "path": "status",
          "equals": "ok"
        },
        {
          "path": "session.transcript_exists",
          "equals": true
        },
        {
          "path": "session.transcript_path",
          "contains": "transcript.jsonl"
        },
        {
          "path": "session.resume_ready",
          "equals": true
        }
      ]
    }
  ]
}
