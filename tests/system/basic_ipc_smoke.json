{
  "name": "basic-ipc-smoke",
  "steps": [
    {
      "name": "read-llm-transport",
      "method": "get_llm_config",
      "params": {
        "path": "backends.openai-codex.transport"
      },
      "assertions": [
        {
          "path": "status",
          "equals": "ok"
        },
        {
          "path": "value",
          "equals": "responses"
        }
      ]
    },
    {
      "name": "list-registered-paths",
      "method": "list_registered_paths",
      "params": {},
      "assertions": [
        {
          "path": "status",
          "equals": "ok"
        },
        {
          "path": "registrations.tool_paths",
          "exists": true
        },
        {
          "path": "registrations.skill_paths",
          "exists": true
        },
        {
          "path": "registrations.entries",
          "exists": true
        },
        {
          "path": "runtime_topology.state_dir",
          "exists": true
        },
        {
          "path": "runtime_topology.registry_dir",
          "exists": true
        }
      ]
    },
    {
      "name": "session-runtime-shape",
      "method": "get_session_runtime",
      "params": {
        "session_id": "system-smoke"
      },
      "assertions": [
        {
          "path": "status",
          "equals": "ok"
        },
        {
          "path": "control_plane.idle_window",
          "equals": 3
        },
        {
          "path": "runtime_topology.loop_state_dir",
          "exists": true
        },
        {
          "path": "runtime_topology.memory_dir",
          "exists": true
        },
        {
          "path": "execution.runtimes.bash.available",
          "equals": true
        },
        {
          "path": "execution.runtimes.python3.available",
          "equals": true
        },
        {
          "path": "execution.runtimes.node.available",
          "equals": true
        },
        {
          "path": "execution.utilities.cat.available",
          "equals": true
        },
        {
          "path": "execution.utilities.find.available",
          "equals": true
        },
        {
          "path": "execution.direct_execution.available",
          "equals": true
        },
        {
          "path": "execution.embedded.status",
          "equals": "documentation_only"
        },
        {
          "path": "execution.embedded.recommendation",
          "contains": "textual skills"
        },
        {
          "path": "session.resume_ready",
          "exists": true
        },
        {
          "path": "memory.summary_path",
          "exists": true
        },
        {
          "path": "memory.categories.general",
          "exists": true
        },
        {
          "path": "context_flow.memory_prompt_ready",
          "exists": true
        },
        {
          "path": "context_flow.session_resume_ready",
          "exists": true
        },
        {
          "path": "loop_snapshot",
          "exists": true
        }
      ]
    },
    {
      "name": "session-usage-shape",
      "method": "get_usage",
      "params": {
        "session_id": "system-smoke"
      },
      "assertions": [
        {
          "path": "scope",
          "equals": "session"
        },
        {
          "path": "usage.prompt_tokens",
          "exists": true
        }
      ]
    }
  ]
}
